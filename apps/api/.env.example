# Aarogya Atlas API config

# Postgres (local Postgres 17 from `brew services start postgresql@17`)
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/aarogya

# Cloud LLM (supervisor reasoning + tool calling) — Groq, OpenAI-compatible.
# Free tier: 30 RPM / 1,000 RPD. Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Cloud multimodal (vision triage) — Google Gemini Flash-Lite.
# Free tier: 15 RPM / 1,000 RPD. Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash-lite
GEMINI_EMBED_MODEL=text-embedding-004

# Local Ollama (PHI-safe enterprise-deployment mode — hospital VPC).
# Optional: when GOOGLE_API_KEY is set, vision auto-routes to Gemini cloud.
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_CHAT_MODEL=qwen2.5:32b-instruct-q4_K_M
LOCAL_EMBED_MODEL=bge-m3
EMBED_DIM=1024

# Geographic scope for the demo
DEFAULT_STATE=Karnataka

# Databricks (MLflow tracing target + Mosaic AI Vector Search). Optional.
DATABRICKS_HOST=
DATABRICKS_TOKEN=
